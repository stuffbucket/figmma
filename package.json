{
  "name": "@stuffbucket/figmma",
  "version": "1.0.3",
  "description": "MCP server with real-time observability dashboard",
  "main": "dist/index.js",
  "bin": {
    "figmma": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && vite build",
    "build:site": "cd site && npm install && npm run build",
    "build:server": "tsc",
    "build:ui": "vite build",
    "mcp": "tsx src/index.ts",
    "dashboard": "tsx src/dashboard/server.ts",
    "dev": "tsx src/dashboard/server.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "npx tsx test/unit.ts && npx tsx test/e2e.ts --tools",
    "postinstall": "node scripts/postinstall.mjs",
    "preuninstall": "node scripts/preuninstall.mjs",
    "prepare": "husky"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "dashboard"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "@types/ws": "^8.18.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  },
  "lint-staged": {
    "*.{ts,mts,mjs,js,json,html,css,md,yml,yaml}": "prettier --write",
    "src/**/*.ts": "eslint --fix"
  }
}
